# 前端请求基地址。开发模式建议保持相对路径，走 Vite 代理，规避 CORS。
VITE_API_BASE_URL=/api/v1

# Vite 开发代理目标（DriveServer 地址）
# 按你的后端实际地址和端口修改。
# 不要把真实公网 IP 或域名提交到仓库；仅保存在本地 .env.development
VITE_PROXY_TARGET=http://localhost:8080

# WebSocket 地址。若留空，则默认使用当前站点同源的 /ws/alerts
# 只有前后端不共域时才需要显式配置
# VITE_WS_BASE_URL=ws://localhost:8080/ws/alerts
